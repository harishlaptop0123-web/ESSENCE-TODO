{
  "name": "Note",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pinned": {
      "type": "boolean",
      "default": false
    },
    "color": {
      "type": "string",
      "default": "#ffffff"
    }
  },
  "required": [
    "title"
  ]
}